####
# Copybara version override — BCR only carries 0.0.0-20240326-6485af6; use
# archive_override to pin to the 2026-03-30 release without waiting for BCR.
# The bazel_dep version in misc.MODULE.bazel is superseded by this override.
archive_override(
    module_name = "copybara",
    integrity = "sha256-b+P4WPdc2JBbJXO8JGW6pbAP6Qqyo59p1CqKENHtAdw=",
    strip_prefix = "copybara-20260330",
    urls = ["https://github.com/google/copybara/archive/refs/tags/v20260330.tar.gz"],
)

# aspect_rules_py 1.10.0 has a bug in _map_srcs (py_pex_binary.bzl): generated
# namespace __init__.py files from rules_python produce a bazel-out/ --dep path
# alongside the source-tree path, causing pex to fail with MetadataError.
# Patch normalises f.path against f.root.path so uniquify=True collapses them.
archive_override(
    module_name = "aspect_rules_py",
    integrity = "sha256-xnVgCx0NMMy61LPIJ2KbDteH3fYwMDS+l5CU46lHKZo=",
    patch_strip = 1,
    patches = ["//build/patches:aspect_rules_py_pex_generated_deps.patch"],
    strip_prefix = "rules_py-1.10.0",
    urls = ["https://github.com/aspect-build/rules_py/releases/download/v1.10.0/rules_py-v1.10.0.tar.gz"],
)
