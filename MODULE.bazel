####
# OCI image building (rules_oci + rules_pkg) — required by mlody-image-builder
bazel_dep(name = "rules_oci", version = "2.0.0")
bazel_dep(name = "rules_pkg", version = "1.0.1")

oci = use_extension("@rules_oci//oci:extensions.bzl", "oci")
oci.pull(
    name = "distroless_base",
    # gcr.io/distroless/base pinned at a stable digest for reproducibility.
    digest = "sha256:b0510424f0c7c1d6fdae75ef5c1d349fa72d312e96f69728fad6beb04755b8b4",
    image = "gcr.io/distroless/base",
    platforms = [
        "linux/amd64",
        "linux/arm64",
    ],
)
use_repo(oci, "distroless_base", "distroless_base_linux_amd64", "distroless_base_linux_arm64")

oci.pull(
    name = "distroless_python3",
    # gcr.io/distroless/python3-debian12 pinned at a stable digest for reproducibility.
    digest = "sha256:e19b29c8473bed88f8b6e31e49d1133d1bdb2bf9c0af7e82d0e7434f7c036a63",
    image = "gcr.io/distroless/python3-debian12",
    platforms = [
        "linux/amd64",
        "linux/arm64",
    ],
)
use_repo(oci, "distroless_python3", "distroless_python3_linux_amd64", "distroless_python3_linux_arm64")

oci.pull(
    name = "debian_slim",
    # docker.io/library/debian:12-slim — has bash, needed for aspect_rules_py
    # launchers which are bash scripts that set up the hermetic Python venv.
    digest = "sha256:f06537653ac770703bc45b4b113475bd402f451e85223f0f2837acbf89ab020a",
    image = "debian",
    platforms = [
        "linux/amd64",
        "linux/arm64",
    ],
    tag = "12-slim",
)
use_repo(oci, "debian_slim", "debian_slim_linux_amd64", "debian_slim_linux_arm64")
