load("//mlody/common/values.mlody")
load("@common//:types.mlody", "top", "typedef", "string", "integer", "bool", "record", "vector")
load("//mlody/common/locations.mlody")
load("//mlody/common/representation.mlody", "json", "text", "parquet", "csv")

typedef(
    name = "celebA-row",
    base = record(
	fields = [
	    value(name="image", type=top()),
	    value(name="celeb_id", type=integer()),
	    value(name="5_o_Clock_Shadow", type=bool()),
	    value(name="Arched_Eyebrows", type=bool()),
	    value(name="Attractive", type=bool()),
	    value(name="Bags_Under_Eyes", type=bool()),
	    value(name="Bald", type=bool()),
	    value(name="Bangs", type=bool()),
	    value(name="Big_Lips", type=bool()),
	    value(name="Big_Nose", type=bool()),
	    value(name="Black_Hair", type=bool()),
	    value(name="Blond_Hair", type=bool()),
	    value(name="Blurry", type=bool()),
	    value(name="Brown_Hair", type=bool()),
	    value(name="Bushy_Eyebrows", type=bool()),
	    value(name="Chubby", type=bool()),
	    value(name="Double_Chin", type=bool()),
	    value(name="Eyeglasses", type=bool()),
	    value(name="Goatee", type=bool()),
	    value(name="Gray_Hair", type=bool()),
	    value(name="Heavy_Makeup", type=bool()),
	    value(name="High_Cheekbones", type=bool()),
	    value(name="Male", type=bool()),
	    value(name="Mouth_Slightly_Open", type=bool()),
	    value(name="Mustache", type=bool()),
	    value(name="Narrow_Eyes", type=bool()),
	    value(name="No_Beard", type=bool()),
	    value(name="Oval_Face", type=bool()),
	    value(name="Pale_Skin", type=bool()),
	    value(name="Pointy_Nose", type=bool()),
	    value(name="Receding_Hairline", type=bool()),
	    value(name="Rosy_Cheeks", type=bool()),
	    value(name="Sideburns", type=bool()),
	    value(name="Smiling", type=bool()),
	    value(name="Straight_Hair", type=bool()),
	    value(name="Wavy_Hair", type=bool()),
	    value(name="Wearing_Earrings", type=bool()),
	    value(name="Wearing_Hat", type=bool()),
	    value(name="Wearing_Lipstick", type=bool()),
	    value(name="Wearing_Necklace", type=bool()),
	    value(name="Wearing_Necktie", type=bool()),
	    value(name="Young", type=bool()),
	],
    ),
)
    
typedef(
    name = "celebA",
    base = record(
	fields = [
	    value(name="info",    type=top(), representation=json(), location=posix(path="dataset_info.json")),
	    value(name="license", type=top(), representation=text(), location=posix(path="LICENSE")),
	    value(name="readme",  type=top(), representation=text(markup="markdown"), location=posix(path="README.md")),
	    # instead of globbing, we should be able to have regex with group capture and be able to state that a specific group is an integer and the path should be sorted by that integer.
	    # or maybe better once we have more complex searches we can map those filenames to tuples/record and do searching/sorting there
	    #
	    # Also, a parquet has to be of type vector[T] if T is declared we can use it as schema (although we need to workout the details of how it is actually accessed from within the representation).
	    # If T is undeclared than we have no schema (right now it is not allowed, but we should permit that)
	    value(name="train",   type = vector(element_type=":celebA-row"), representation=parquet(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/train-*.parquet")),
	    value(name="valid",   type = vector(element_type=":celebA-row"), representation=parquet(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/valid-*.parquet")),
	    value(name="test",   type = vector(element_type=":celebA-row"), representation=parquet(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/test-*.parquet")),
	],
    ))

typedef(
    name = "celebA-csv",
    base = record(
	fields = [
	    value(name="info",    type=top(), representation=json(), location=posix(path="dataset_info.json")),
	    value(name="license", type=top(), representation=text(), location=posix(path="LICENSE")),
	    value(name="readme",  type=top(), representation=text(markup="markdown"), location=posix(path="README.md")),
	    # instead of globbing, we should be able to have regex with group capture and be able to state that a specific group is an integer and the path should be sorted by that integer.
	    # or maybe better once we have more complex searches we can map those filenames to tuples/record and do searching/sorting there
	    #
	    # Also, a parquet has to be of type vector[T] if T is declared we can use it as schema (although we need to workout the details of how it is actually accessed from within the representation).
	    # If T is undeclared than we have no schema (right now it is not allowed, but we should permit that)
	    value(name="train",   type = vector(element_type=":celebA-row"), representation=csv(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/train-*.csv")),
	    value(name="valid",   type = vector(element_type=":celebA-row"), representation=csv(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/valid-*.csv")),
	    value(name="test",   type = vector(element_type=":celebA-row"), representation=csv(schema=":celebA-row", multifile=True), location=posix(path="img_align+identity+attr/test-*.csv")),
	],
    ))

# we should be able to use select() when we have it to decide the type
value(
    name = "celebA-dataset",
    type = ":celebA",
    location = posix(path="~/.cache/mlody/artifacts/huggingface/datasets/flwrlabs/celeba/2d738f56e0e7f925ea36ae7c808ea925264aacec"),
)

# Note: this is for demo purposes only, the "thing" at that location is parquet files
value(
    name = "celebA-dataset-csv",
    type = ":celebA-csv",
    location = posix(path="~/.cache/mlody/artifacts/huggingface/datasets/flwrlabs/celeba/2d738f56e0e7f925ea36ae7c808ea925264aacec"),
)
