#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git -C "$(dirname "${BASH_SOURCE[0]}")" rev-parse --show-toplevel)"
TARGET="//mlody/teams/framera/yolo26:framera_yolo26"

cd "$ROOT_DIR"
exec bazel run \
  --run_under='env __NV_PRIME_RENDER_OFFLOAD=1 __GLX_VENDOR_LIBRARY_NAME=nvidia __VK_LAYER_NV_optimus=NVIDIA_only' \
  "$TARGET" -- \
  "$@"

